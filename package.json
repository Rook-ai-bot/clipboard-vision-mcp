    "dev": "bun --watch src/index.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "groq-sdk": "^0.25.0",
    "zod": "^4.3.6"
  },
  "keywords": ["mcp", "vision", "clipboard", "groq", "llama"],
