{
  "mcp": {
    "clipboard-vision": {
      "type": "local",
      "command": ["bun", "run", "/absolute/path/to/clipboard-vision-mcp/src/index.ts"],
      "environment": {
        "GROQ_API_KEY": "gsk_your_key_here"
      },
      "enabled": true
    }
  },
  "keybinds": {
    "input_paste": "ctrl+v",
    "input_paste_image": "alt+v"
  }
}
